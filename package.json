{
	"name": "semutssh-copilot",
	"publisher": "semutdev",
	"displayName": "Semutssh Copilot",
	"description": "Integrates SemutSSH AI API into VS Code Copilot Chat via LiteLLM-compatible endpoints.",
	"repository": "https://github.com/semutdev/semutssh-copilot",
	"version": "1.0.0",
	"engines": {
		"vscode": ">=1.85.0"
	},
	"categories": [
		"AI",
		"Other"
	],
	"keywords": [
		"copilot",
		"ai",
		"litellm",
		"semutssh"
	],
	"license": "MIT",
	"activationEvents": [
		"onLanguageModelChatProvider:semutssh",
		"onStartupFinished"
	],
	"contributes": {
		"languageModelChatProviders": [
			{
				"vendor": "semutssh",
				"displayName": "Semutssh",
				"managementCommand": "semutssh.configure"
			}
		],
		"commands": [
			{
				"command": "semutssh.configure",
				"title": "Configure Semutssh"
			},
			{
				"command": "semutssh.showModels",
				"title": "Semutssh: Show Available Models"
			},
			{
				"command": "semutssh.reloadModels",
				"title": "Semutssh: Reload Models"
			},
			{
				"command": "semutssh.checkConnection",
				"title": "Semutssh: Check Connection"
			},
			{
				"command": "semutssh.reset",
				"title": "Semutssh: Reset All Configuration"
			},
			{
				"command": "semutssh.manageModels",
				"title": "Semutssh: Manage Models"
			}
		],
		"configuration": {
			"title": "Semutssh Copilot",
			"properties": {
				"semutssh.baseUrl": {
					"type": "string",
					"default": "https://ai.semutssh.com/v1",
					"description": "Base URL for the Semutssh API server."
				},
				"semutssh.apiKeySecretRef": {
					"type": "string",
					"default": "default",
					"description": "Reference name for the API key stored in VS Code SecretStorage."
				},
				"semutssh.customModels": {
					"type": "array",
					"default": [],
					"description": "List of custom models added manually by the user."
				},
				"semutssh.hiddenModels": {
					"type": "array",
					"default": [],
					"description": "List of model IDs to hide from the model picker."
				},
				"semutssh.defaultModel": {
					"type": "string",
					"default": "",
					"description": "Model ID to use as the default model."
				}
			}
		}
	},
	"main": "./dist/extension.js",
	"browser": "./dist/web/extension.js",
	"enabledApiProposals": [
		"chatProvider",
		"languageModelCapabilities",
		"languageModelProxy",
		"languageModelSystem",
		"languageModelThinkingPart",
		"languageModelToolResultAudience",
		"languageModelToolSupportsModel"
	],
	"scripts": {
		"clean": "rm -rf ./dist ./out ./coverage ./test-results",
		"clean:build": "rm -rf ./dist ./out",
		"compile": "tsc -p ./",
		"package": "npm run clean:build && tsc --noEmit && node esbuild.js --production && npx vsce package",
		"lint": "eslint --fix",
		"lint:check": "eslint",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile",
		"test": "xvfb-run vscode-test --args=\"--no-sandbox\"",
		"download-api": "dts main && mv vscode.d.ts src/ && dts dev && mv vscode.proposed.*.d.ts src/",
		"postinstall": "npm run download-api"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "^22.19.11",
		"@types/sinon": "^21.0.0",
		"@types/vscode": "^1.85.0",
		"@vscode/dts": "^0.4.1",
		"@vscode/test-electron": "^2.5.2",
		"@vscode/vsce": "^3.7.0",
		"esbuild": "^0.27.3",
		"eslint": "^10.0.0",
		"prettier": "^3.1.0",
		"rimraf": "^6.0.1",
		"sinon": "^21.0.1",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.39.0"
	}
}
